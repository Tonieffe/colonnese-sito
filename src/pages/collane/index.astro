---
// src/pages/collane/index.astro
const title = "Le nostre Collane | Colonnese Editore";

// Dati d'esempio per Keystatic
const collane = [
  { 
    nome: "Lo Specchio di Silvia", 
    slug: "lo-specchio-di-silvia", 
    descrizione: "Opere rare, riscoperte e perle della letteratura napoletana ed europea.",
    colore: "#bc2026" 
  },
  { 
    nome: "La Fenice", 
    slug: "la-fenice", 
    descrizione: "Classici intramontabili in edizioni di pregio per bibliografi esigenti.",
    colore: "#1a1a1a" 
  },
  { 
    nome: "I Tascabili", 
    slug: "i-tascabili", 
    descrizione: "Cultura a portata di mano: grandi storie in formato agile.",
    colore: "#555" 
  }
];
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;700&family=Inter:wght@300;600&display=swap" rel="stylesheet">
    <style>
      :root { --colonnese-red: #bc2026; --text-dark: #1a1a1a; }
      body { font-family: 'Inter', sans-serif; background: #fff; margin: 0; }
      .container { max-width: 1200px; margin: 0 auto; padding: 60px 20px; }
      
      .header-sezione { text-align: center; margin-bottom: 60px; }
      .header-sezione h1 { font-family: 'Lora', serif; font-size: 3rem; font-weight: 400; }

      .collane-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); 
        gap: 30px; 
      }

      .collana-card { 
        text-decoration: none; 
        color: inherit; 
        padding: 40px; 
        border: 1px solid #eee; 
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: #fdfdfd;
      }

      .collana-card:hover { 
        border-color: var(--colonnese-red);
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
      }

      .linea-colore { width: 40px; height: 3px; margin-bottom: 20px; }
      
      h2 { font-family: 'Lora', serif; font-size: 1.8rem; margin: 0 0 15px 0; }
      p { color: #666; font-size: 0.95rem; line-height: 1.5; }
    </style>
  </head>
  <body>
    <main class="container">
      <div class="header-sezione">
        <h1>Le Collane</h1>
      </div>

      <div class="collane-grid">
        {collane.map((c) => (
          <a href={`/collane/${c.slug}`} class="collana-card">
            <div class="linea-colore" style={`background-color: ${c.colore}`}></div>
            <h2>{c.nome}</h2>
            <p>{c.descrizione}</p>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>