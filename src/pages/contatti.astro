---
// src/pages/contatti.astro
const title = "Contatti | Colonnese Editore";
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
      :root { --colonnese-red: #bc2026; --text-dark: #1a1a1a; --border: #e5e5e5; --bg-pale: #f9f9f9; }
      body { font-family: 'Inter', sans-serif; color: var(--text-dark); background: #fff; margin: 0; }
      
      .main-header { border-bottom: 1px solid var(--border); padding: 30px 0; text-align: center; background: #fff; position: sticky; top: 0; z-index: 100; }
      .logo { font-family: 'Lora', serif; font-size: 1.8rem; text-decoration: none; color: #000; text-transform: uppercase; letter-spacing: 4px; }
      
      .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

      /* HERO SECTION */
      .contact-hero { padding: 100px 0; text-align: center; border-bottom: 1px solid var(--border); }
      .contact-hero h1 { font-family: 'Lora', serif; font-size: 3.5rem; font-weight: 400; margin: 0; }
      .contact-hero p { color: var(--colonnese-red); text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; font-weight: 700; margin-bottom: 15px; }

      /* SEZIONE DOPPIA: INFO & FORM */
      .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; padding: 100px 0; }
      
      .info-side h2 { font-family: 'Lora', serif; font-size: 2.2rem; margin-bottom: 30px; }
      .location-box { margin-bottom: 40px; padding-left: 20px; border-left: 2px solid var(--colonnese-red); }
      .location-box strong { display: block; font-size: 1.1rem; margin-bottom: 5px; }
      .location-box p { color: #666; margin: 0; }

      /* FORM DESIGN */
      .form-side { background: var(--bg-pale); padding: 50px; border: 1px solid var(--border); }
      .form-group { margin-bottom: 25px; }
      .form-group label { display: block; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px; margin-bottom: 8px; }
      .form-group input, .form-group textarea { 
        width: 100%; padding: 15px; border: 1px solid var(--border); background: #fff; 
        font-family: 'Inter', sans-serif; transition: 0.3s; box-sizing: border-box;
      }
      .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--colonnese-red); }
      
      .btn-send { 
        background: var(--text-dark); color: #fff; border: none; padding: 20px 40px; 
        text-transform: uppercase; font-weight: 700; letter-spacing: 2px; cursor: pointer; transition: 0.3s; width: 100%;
      }
      .btn-send:hover { background: var(--colonnese-red); }

      /* MAPPA */
      .map-container { height: 450px; background: #eee; border-top: 1px solid var(--border); }
      iframe { width: 100%; height: 100%; border: none; filter: grayscale(100%) contrast(1.2); opacity: 0.8; }

      footer { background: var(--text-dark); color: #fff; padding: 60px 0; text-align: center; }

      @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 50px; } }
    </style>
  </head>
  <body>

    <header class="main-header">
      <a href="/" class="logo">Colonnese</a>
    </header>

    <main>
      <section class="contact-hero">
        <div class="container">
          <p>Mettiamoci in contatto</p>
          <h1>Scrivici o vieni a trovarci</h1>
        </div>
      </section>

      <div class="container">
        <div class="contact-grid">
          <div class="info-side">
            <h2>Le sedi storiche</h2>
            <div class="location-box">
              <strong>Libreria San Pietro a Majella</strong>
              <p>Via San Pietro a Majella 32/33, 80138 Napoli</p>
              <p>Telefono: +39 081 459858</p>
            </div>
            <div class="location-box">
              <strong>Sede Amministrativa</strong>
              <p>Email: info@colonnese.it</p>
              <p>Orari: Lun-Ven 09:00 - 18:30</p>
            </div>
          </div>

          <div class="form-side">
            <form action="https://formspree.io/f/info@colonnese.it" method="POST">
              <div class="form-group">
                <label for="name">Nome e Cognome</label>
                <input type="text" id="name" name="name" placeholder="Inserisci il tuo nome" required />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="_replyto" placeholder="tua@email.it" required />
              </div>
              <div class="form-group">
                <label for="message">Messaggio</label>
                <textarea id="message" name="message" rows="5" placeholder="Come possiamo aiutarti?" required></textarea>
              </div>
              <button type="submit" class="btn-send">Invia Messaggio</button>
            </form>
          </div>
        </div>
      </div>

      <section class="map-container">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m13!1d3021.9!2d14.25!3d40.85!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x133b084666666667%3A0x6666666666666666!2sColonnese%20Libreria!5e0!3m2!1sit!2sit!4v1620000000000!5m2!1sit!2sit"></iframe>
      </section>
    </main>

    <footer>
      <div class="container">
        <p>© 2026 Colonnese Editore — Napoli</p>
      </div>
    </footer>

  </body>
</html>